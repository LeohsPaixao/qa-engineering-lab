{
  "name": "playwright-ui-tests",
  "version": "2.0.3",
  "description": "Project Tests Playwright",
  "author": "Leonardo Paixao <leonardohspaixao@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "play:install": "playwright install",
    "play:e2e": "PW_PROJECT_NAME=e2e npx playwright test --project=e2e",
    "play:api": "PW_PROJECT_NAME=api npx playwright test --project=api",
    "play:ct": "PW_PROJECT_NAME=component npx playwright test --project=component",
    "play:ui": "playwright test --ui",
    "play:report": "playwright show-report",
    "lint": "eslint --fix"
  },
  "dependencies": {
    "@faker-js/faker": "9.8.0",
    "dotenv": "16.4.5"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "22.19.1",
    "eslint": "9.20.0",
    "eslint-plugin-playwright": "2.2.0"
  }
}